# Local environment for SQL Migrator
# Copy this file to .env and edit values as needed.

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
SQLALCHEMY_DATABASE_URI=sqlite:///backend/database/app_data.db
PORT=5000

# Optional Postgres settings for helper scripts
# POSTGRES_USER=your_username
# POSTGRES_PASSWORD=your_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=your_database
# USE_SQLITE_FALLBACK=true

# Optional Excel import helper values
# EXCEL_FILE_PATH=Stockason_10032026.xlsx
